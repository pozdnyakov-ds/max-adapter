# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Секрет webhook (проверка входящих запросов от MAX)
MAX_SECRET=ТВОЙ_WEBHOOK_SECRET

# Токен бота MAX (для отправки сообщений через API)
MAX_TOKEN=ТВОЙ_MAX_BOT_TOKEN

# URL OpenClaw API
OPENCLAW_URL=http://host.docker.internal:18789

# Токен OpenClaw Gateway
OPENCLAW_TOKEN=ТВОЙ_GATEWAY_TOKEN

# ID агента OpenClaw
OPENCLAW_AGENT_ID=main

# Allowlist пользователей MAX (через запятую, без пробелов)
# Если не задано — бот отвечает всем
# ALLOWED_USERS=4399699,другой_id

# Секрет для /openclaw/announce endpoint
# OpenClaw передаёт его в заголовке Authorization: Bearer <token>
OPENCLAW_ANNOUNCE_SECRET=change_me

# TTL хранилища маршрутов в часах (по умолчанию 168 = 7 дней)
# ROUTE_STORE_TTL_HOURS=168
